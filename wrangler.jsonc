{
  // Cloudflare Workers static-assets config.
  // With this file present, `wrangler deploy` uploads the Vite build in ./dist
  // directly and skips the framework "auto-config" (which otherwise installs
  // @cloudflare/vite-plugin and re-runs the build with an incompatible Node).
  "name": "kdcodes",
  "compatibility_date": "2026-06-25",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
